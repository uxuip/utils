{
  "name": "@uxuip/utils",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@9.1.0",
  "description": "Opinionated collection of common JavaScript / TypeScript utils",
  "author": "uxuip <uxuip@outlook.com>",
  "license": "MIT",
  "homepage": "https://github.com/uxuip/utils#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uxuip/utils.git"
  },
  "bugs": {
    "url": "https://github.com/uxuip/utils/issues"
  },
  "keywords": [
    "utils"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "npm run build --watch",
    "lint": "eslint .",
    "lint-fix": "npm run lint --fix",
    "prepublishOnly": "npm run build",
    "bump": "bumpp --commit --no-push --tag",
    "release": "npm publish",
    "start": "esno src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest"
  },
  "devDependencies": {
    "@rollup/plugin-alias": "^5.1.0",
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@types/node": "^20.12.10",
    "@types/throttle-debounce": "^5.0.2",
    "@uxuip/eslint-config": "3.0.6-beta.1",
    "bumpp": "^9.4.1",
    "eslint": "^9.15.0",
    "esno": "^4.7.0",
    "p-limit": "^5.0.0",
    "rollup": "^4.17.2",
    "rollup-plugin-dts": "^6.1.0",
    "rollup-plugin-esbuild": "^6.1.1",
    "throttle-debounce": "5.0.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vitest": "^1.6.0"
  }
}
